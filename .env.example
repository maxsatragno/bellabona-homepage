# Sanity — required
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-01

# Sanity read token (optional, only needed for draft mode / preview)
SANITY_API_READ_TOKEN=

# Shared secret between Sanity webhook and /api/revalidate
SANITY_REVALIDATE_SECRET=

# Public site URL — used to build canonicals and OG absolute URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
